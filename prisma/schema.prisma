generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model counter {
  id Int @id @default(autoincrement()) @map("カウンターID")
  updated_at Int? @map("最終情報更新日")
  is_closed Int? @map("廃止フラグ")
  approved_at Int? @map("承認年月日")
  closed_at String? @map("廃止年月日")
  company_name_ja String @map("事業者名（日本語）")
  company_name_en String? @map("事業者名（英語）")
  company_zip_code Int @map("事業者住所_郵便番号")
  company_pref_code Int @map("事業者住所_都道府県コード")
  company_city_code Int @map("事業者住所_市町村コード")
  company_address_ja String? @map("事業者住所_大字丁目・番地等（日本語）")
  company_address_en String? @map("事業者住所_大字丁目・番地等（英語）")
  counter_name_ja String @map("カウンター名称（日本語）")
  counter_name_en String @map("カウンター名称（英語）")
  zip_code Int @map("カウンター住所_郵便番号")
  pref_code Int @map("カウンター住所_都道府県コード")
  city_code Int @map("カウンター住所_市町村コード")
  address_ja String? @map("カウンター住所_大字丁目・番地等（日本語）")
  address_en String? @map("カウンター住所_大字丁目・番地等（英語）")
  floor String? @map("カウンター住所_建物階層")
  latitude Float @map("カウンター住所_緯度")
  longitude Float @map("カウンター住所_経度")
  facility_type String? @map("カウンター住所_施設類型")
  station_name_ja String? @map("カウンター住所_設置公共交通機関名（又は最寄公共交通機関名）（日本語）")
  station_name_en String? @map("カウンター住所_設置公共交通機関名（又は最寄公共交通機関名）（英語）")
  phone String? @map("カウンター電話番号")
  website_url String? @map("外部リンクＵＲＬ")
  mon_open String? @map("営業時間_月曜日_開始時間")
  mon_close String? @map("営業時間_月曜日_終了時間")
  mon_is_holiday Int? @map("営業時間_月曜日_定休日フラグ")
  tue_open String? @map("営業時間_火曜日_開始時間")
  tue_close String? @map("営業時間_火曜日_終了時間")
  tue_is_holiday Int? @map("営業時間_火曜日_定休日フラグ")
  wed_open String? @map("営業時間_水曜日_開始時間")
  wed_close String? @map("営業時間_水曜日_終了時間")
  wed_is_holiday Int? @map("営業時間_水曜日_定休日フラグ")
  thu_open String? @map("営業時間_木曜日_開始時間")
  thu_close String? @map("営業時間_木曜日_終了時間")
  thu_is_holiday Int? @map("営業時間_木曜日_定休日フラグ")
  fri_open String? @map("営業時間_金曜日_開始時間")
  fri_close String? @map("営業時間_金曜日_終了時間")
  fri_is_holiday Int? @map("営業時間_金曜日_定休日フラグ")
  sat_open String? @map("営業時間_土曜日_開始時間")
  sat_close String? @map("営業時間_土曜日_終了時間")
  sat_is_holiday Int? @map("営業時間_土曜日_定休日フラグ")
  sun_open String? @map("営業時間_日曜日_開始時間")
  sun_close String? @map("営業時間_日曜日_終了時間")
  sun_is_holiday Int? @map("営業時間_日曜日_定休日フラグ")
  hours_notes_ja String? @map("営業時間_その他（日本語）")
  hours_notes_en String? @map("営業時間_その他（英語）")
  lang_en Int @map("対応可能言語_英語フラグ")
  lang_zh_cn Int @map("対応可能言語_中国語（簡体字）フラグ")
  lang_zh_tw Int @map("対応可能言語_中国語（繁体字）フラグ")
  lang_ko Int @map("対応可能言語_韓国語フラグ")
  lang_th Int @map("対応可能言語_タイ語フラグ")
  lang_others_ja String? @map("対応可能言語_その他（日本語）")
  lang_others_en String? @map("対応可能言語_その他（英語）")
  is_duty_free String? @map("免税店プラグ")
  is_jnto_office String? @map("JNTO観光案内所フラグ")
  has_storage Int @map("一時預かりフラグ")
  storage_fee_fixed String? @map("一時預かり_料金_固定")
  storage_fee_max String? @map("一時預かり_料金_変動上限値")
  storage_fee_min String? @map("一時預かり_料金_変動下限値")
  storage_item_suitcase String? @map("一時預かり_取扱可能品目_スーツケースフラグ")
  storage_item_chilled String? @map("一時預かり_取扱可能品目_クール品フラグ")
  storage_item_souvenir String? @map("一時預かり_取扱可能品目_土産品フラグ")
  storage_max_dimensions String? @map("一時預かり_取扱可能品目_3辺長合計上限値")
  storage_max_weight String? @map("一時預かり_取扱可能品目_最大重量上限値")
  storage_max_value String? @map("一時預かり_取扱可能品目_取扱金額上限値")
  storage_notes_ja String? @map("一時預かり_取扱可能品目_その他（日本語）")
  storage_notes_en String? @map("一時預かり_取扱可能品目_その他（英語）")
  storage_insurance_limit String? @map("一時預かり_補償内容_取扱金額上限値")
  storage_insurance_notes_ja String? @map("一時預かり_補償内容_その他（日本語）")
  storage_insurance_notes_en String? @map("一時預かり_補償内容_その他（英語）")
  has_delivery_sameday Int @map("配送_当日配送フラグ")
  delivery_sameday_fee_fixed String? @map("配送_当日配送_料金_固定")
  delivery_sameday_fee_max String? @map("配送_当日配送_料金_変動上限値")
  delivery_sameday_fee_min String? @map("配送_当日配送_料金_変動下限値")
  delivery_sameday_item_suitcase String? @map("配送_当日配送_取扱可能品目_スーツケースフラグ")
  delivery_sameday_item_chilled String? @map("配送_当日配送_取扱可能品目_クール品フラグ")
  delivery_sameday_item_souvenir String? @map("配送_当日配送_取扱可能品目_土産品フラグ")
  delivery_sameday_max_dimensions String? @map("配送_当日配送_取扱可能品目_3辺長合計上限値")
  delivery_sameday_max_weight String? @map("配送_当日配送_取扱可能品目_最大重量上限値")
  delivery_sameday_max_value String? @map("配送_当日配送_取扱可能品目_取扱金額上限値")
  delivery_sameday_notes_ja String? @map("配送_当日配送_取扱可能品目_その他（日本語）")
  delivery_sameday_notes_en String? @map("配送_当日配送_取扱可能品目_その他（英語）")
  delivery_sameday_insurance_limit String? @map("配送_当日配送_補償内容_取扱金額上限値")
  delivery_sameday_insurance_notes_ja String? @map("配送_当日配送_補償内容_その他（日本語）")
  delivery_sameday_insurance_notes_en String? @map("配送_当日配送_補償内容_その他（英語）")
  delivery_sameday_cutoff_time String? @map("配送_当日配送_受付時間〆切")
  delivery_sameday_last_time String? @map("配送_当日配送_最終配送時間")
  delivery_sameday_dest_ja String? @map("配送_当日配送_配送先（日本語）")
  delivery_sameday_dest_en String? @map("配送_当日配送_配送先（英語）")
  has_delivery_standard Int @map("配送_一般配送フラグ")
  delivery_standard_fee_fixed String? @map("配送_一般配送_料金_固定")
  delivery_standard_fee_max String? @map("配送_一般配送_料金_変動上限値")
  delivery_standard_fee_min String? @map("配送_一般配送_料金_変動下限値")
  delivery_standard_item_suitcase String? @map("配送_一般配送_取扱可能品目_スーツケースフラグ")
  delivery_standard_item_chilled String? @map("配送_一般配送_取扱可能品目_クール品フラグ")
  delivery_standard_item_souvenir String? @map("配送_一般配送_取扱可能品目_土産品フラグ")
  delivery_standard_max_dimensions String? @map("配送_一般配送_取扱可能品目_3辺長合計上限値")
  delivery_standard_max_weight String? @map("配送_一般配送_取扱可能品目_最大重量上限値")
  delivery_standard_max_value String? @map("配送_一般配送_取扱可能品目_取扱金額上限値")
  delivery_standard_notes_ja String? @map("配送_一般配送_取扱可能品目_その他（日本語）")
  delivery_standard_notes_en String? @map("配送_一般配送_取扱可能品目_その他（英語）")
  delivery_standard_insurance_limit String? @map("配送_一般配送_補償内容_取扱金額上限値")
  delivery_standard_insurance_notes_ja String? @map("配送_一般配送_補償内容_その他（日本語）")
  delivery_standard_insurance_notes_en String? @map("配送_一般配送_補償内容_その他（英語）")
  delivery_standard_is_nationwide String? @map("配送_一般配送_配送先_全国各地発送フラグ")
  delivery_standard_dest_ja String? @map("配送_一般配送_配送先_その他（日本語）")
  delivery_standard_dest_en String? @map("配送_一般配送_配送先_その他（英語）")
  has_delivery_overseas Int @map("配送_海外配送フラグ")
  delivery_overseas_fee_fixed String? @map("配送_海外配送_料金_固定")
  delivery_overseas_fee_max String? @map("配送_海外配送_料金_変動上限値")
  delivery_overseas_fee_min String? @map("配送_海外配送_料金_変動下限値")
  delivery_overseas_item_suitcase String? @map("配送_海外配送_取扱可能品目_スーツケースフラグ")
  delivery_overseas_item_chilled String? @map("配送_海外配送_取扱可能品目_クール品フラグ")
  delivery_overseas_item_souvenir String? @map("配送_海外配送_取扱可能品目_土産品フラグ")
  delivery_overseas_max_dimensions String? @map("配送_海外配送_取扱可能品目_3辺長合計上限値")
  delivery_overseas_max_weight String? @map("配送_海外配送_取扱可能品目_最大重量上限値")
  delivery_overseas_max_value String? @map("配送_海外配送_取扱可能品目_取扱金額上限値")
  delivery_overseas_notes_ja String? @map("配送_海外配送_取扱可能品目_その他（日本語）")
  delivery_overseas_notes_en String? @map("配送_海外配送_取扱可能品目_その他（英語）")
  delivery_overseas_insurance_limit String? @map("配送_海外配送_補償内容_取扱金額上限値")
  delivery_overseas_insurance_notes_ja String? @map("配送_海外配送_補償内容_その他（日本語）")
  delivery_overseas_insurance_notes_en String? @map("配送_海外配送_補償内容_その他（英語）")
  x_full_address_ja String @map("カスタム_カウンター住所_フル") @default("")
}
